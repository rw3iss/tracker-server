# Database (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=tracker

# Redis (for BullMQ queue)
REDIS_URL=redis://localhost:6379

# Server
PORT=4010
NODE_ENV=production

# Route prefix for API endpoints (events, metrics, status, ...). Dashboard
# is always served at DASHBOARD_PATH, independently of this prefix.
# Example: ROUTE_PREFIX=api → tracker.ryanweiss.net/api/events, /api/metrics, ...
ROUTE_PREFIX=api
DASHBOARD_PATH=dashboard

# Optional: custom table name (default: tracker_events)
# TRACKER_TABLE_NAME=tracker_events

# Optional: comma-separated API keys for server-to-server auth
# Generate with: openssl rand -hex 32
# TRACKER_API_KEYS=key1,key2,key3

# Redis ingest consumer (for Go ingest server)
ENABLE_INGEST_CONSUMER=true
REDIS_LIST_KEY=tracker:ingest
