---
// MermaidZoom.astro — global progressive enhancement that turns every
// ```mermaid``` diagram on the page into a click-to-zoom interactive
// view. Loads as a regular client-side module via `<script>` so it
// also handles diagrams added by client navigation.
//
// What it does at runtime:
//   • Walks every astro-mermaid output container (.mermaid wrapper or
//     a <pre class="mermaid"> with an inline SVG inside).
//   • Adds a small "Expand" button overlay.
//   • Click → opens a fullscreen modal containing the SVG, with mouse-
//     wheel zoom and click-drag pan.
//   • Esc / click-outside / close button closes the modal.
//
// No external dependencies — pure DOM + CSS, ~3KB.
---

<style is:global>
    /* The diagram container the integration emits — give it a relative
     * positioning context so we can stick the Expand button on top. */
    .sl-markdown-content :is(.mermaid, mermaid-diagram) {
        position: relative;
        background: var(--sl-color-bg-nav);
        border: 1px solid var(--sl-color-hairline);
        border-radius: 8px;
        padding: 1rem 1rem 0.75rem;
        margin: 1.25rem 0;
        overflow: auto;
    }
    .sl-markdown-content :is(.mermaid, mermaid-diagram) svg {
        max-width: 100%;
        height: auto;
        display: block;
    }

    /* Expand button — appears on hover, top-right corner. */
    .mermaid-expand-btn {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        background: var(--sl-color-accent);
        color: var(--sl-color-white);
        border: none;
        border-radius: 4px;
        padding: 4px 8px;
        font-size: 11px;
        font-weight: 600;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.15s, background 0.15s;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .sl-markdown-content :is(.mermaid, mermaid-diagram):hover .mermaid-expand-btn,
    .mermaid-expand-btn:focus {
        opacity: 1;
    }
    .mermaid-expand-btn:hover { background: var(--sl-color-accent-high); }

    /* Modal */
    .mermaid-modal {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.85);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease;
    }
    .mermaid-modal.is-open {
        opacity: 1;
        pointer-events: auto;
    }
    .mermaid-modal__viewport {
        width: 96vw;
        height: 92vh;
        overflow: hidden;
        position: relative;
        cursor: grab;
        touch-action: none;
    }
    .mermaid-modal__viewport.is-dragging { cursor: grabbing; }
    .mermaid-modal__svg {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) scale(1);
        transform-origin: 0 0;
        max-width: none;
        max-height: none;
        will-change: transform;
        user-select: none;
    }
    .mermaid-modal__controls {
        position: absolute;
        top: 1rem;
        right: 1rem;
        display: flex;
        gap: 6px;
        z-index: 1;
    }
    .mermaid-modal__btn {
        background: rgba(255, 255, 255, 0.12);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 4px;
        padding: 6px 12px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        backdrop-filter: blur(6px);
    }
    .mermaid-modal__btn:hover { background: rgba(255, 255, 255, 0.22); }
    .mermaid-modal__hint {
        position: absolute;
        bottom: 1rem;
        left: 50%;
        transform: translateX(-50%);
        color: rgba(255, 255, 255, 0.6);
        font-size: 12px;
        pointer-events: none;
    }
</style>

<script>
    /**
     * Mermaid zoom enhancement.
     *
     * Wires every Mermaid diagram on the page to a click-to-zoom modal
     * with wheel zoom + click-drag pan. Idempotent — re-runs on every
     * Astro view-transition so navigations don't lose the buttons.
     */
    (function () {
        const ATTACHED = 'data-mermaid-zoom';

        function svgFromHost(host: Element): SVGSVGElement | null {
            // astro-mermaid emits an <svg> inside its container.
            const svg = host.querySelector('svg');
            return svg as SVGSVGElement | null;
        }

        function attach() {
            const hosts = document.querySelectorAll('.mermaid, mermaid-diagram');
            hosts.forEach((host) => {
                if (host.hasAttribute(ATTACHED)) return;
                if (!svgFromHost(host)) return; // not yet rendered
                host.setAttribute(ATTACHED, 'true');

                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'mermaid-expand-btn';
                btn.innerHTML = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h7v2H5v5H3V3Zm0 18h7v-2H5v-5H3v7Zm18 0h-7v-2h5v-5h2v7ZM21 3h-7v2h5v5h2V3Z"/></svg> Expand`;
                btn.setAttribute('aria-label', 'Open diagram in fullscreen');
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const svg = svgFromHost(host);
                    if (svg) openModal(svg);
                });
                (host as HTMLElement).appendChild(btn);
            });
        }

        // ── Modal ─────────────────────────────────────────────────────
        let modal: HTMLDivElement | null = null;
        let viewport: HTMLDivElement | null = null;
        let svgEl: SVGSVGElement | null = null;
        let scale = 1;
        let tx = 0;
        let ty = 0;
        let dragging = false;
        let dragStartX = 0;
        let dragStartY = 0;
        let dragOriginX = 0;
        let dragOriginY = 0;

        function ensureModal(): HTMLDivElement {
            if (modal) return modal;
            modal = document.createElement('div');
            modal.className = 'mermaid-modal';
            modal.innerHTML = `
                <div class="mermaid-modal__viewport">
                    <div class="mermaid-modal__controls">
                        <button class="mermaid-modal__btn" data-action="reset">Reset</button>
                        <button class="mermaid-modal__btn" data-action="close">✕ Close</button>
                    </div>
                    <div class="mermaid-modal__hint">Scroll to zoom · drag to pan · Esc to close</div>
                </div>
            `;
            viewport = modal.querySelector('.mermaid-modal__viewport') as HTMLDivElement;
            document.body.appendChild(modal);

            modal.addEventListener('click', (e) => {
                const target = e.target as HTMLElement;
                if (target === modal) closeModal();
                if (target.dataset?.action === 'close') closeModal();
                if (target.dataset?.action === 'reset') resetTransform();
            });
            viewport!.addEventListener('wheel', onWheel, { passive: false });
            viewport!.addEventListener('mousedown', onMouseDown);
            window.addEventListener('mousemove', onMouseMove);
            window.addEventListener('mouseup',   onMouseUp);
            document.addEventListener('keydown', (e) => {
                if (modal?.classList.contains('is-open') && e.key === 'Escape') closeModal();
            });
            return modal;
        }

        function openModal(srcSvg: SVGSVGElement) {
            const m = ensureModal();
            // Remove any prior cloned svg.
            const prior = m.querySelector('.mermaid-modal__svg');
            if (prior) prior.remove();

            svgEl = srcSvg.cloneNode(true) as SVGSVGElement;
            svgEl.classList.add('mermaid-modal__svg');
            svgEl.removeAttribute('width');
            svgEl.removeAttribute('height');
            svgEl.style.maxWidth = 'none';
            svgEl.style.maxHeight = 'none';
            viewport!.appendChild(svgEl);

            scale = 1; tx = 0; ty = 0;
            applyTransform();
            m.classList.add('is-open');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            if (!modal) return;
            modal.classList.remove('is-open');
            document.body.style.overflow = '';
            const sv = modal.querySelector('.mermaid-modal__svg');
            if (sv) sv.remove();
            svgEl = null;
        }

        function applyTransform() {
            if (!svgEl) return;
            svgEl.style.transform = `translate(-50%, -50%) translate(${tx}px, ${ty}px) scale(${scale})`;
        }

        function resetTransform() {
            scale = 1; tx = 0; ty = 0;
            applyTransform();
        }

        function onWheel(e: WheelEvent) {
            e.preventDefault();
            const delta = -e.deltaY * 0.0015;
            const next = Math.max(0.25, Math.min(8, scale * (1 + delta)));
            // Zoom centred on cursor for natural-feeling wheel zoom.
            if (svgEl && viewport) {
                const rect = viewport.getBoundingClientRect();
                const cx = e.clientX - rect.left - rect.width / 2;
                const cy = e.clientY - rect.top - rect.height / 2;
                const factor = next / scale;
                tx = cx - (cx - tx) * factor;
                ty = cy - (cy - ty) * factor;
                scale = next;
                applyTransform();
            }
        }

        function onMouseDown(e: MouseEvent) {
            if (!viewport) return;
            dragging = true;
            dragStartX = e.clientX;
            dragStartY = e.clientY;
            dragOriginX = tx;
            dragOriginY = ty;
            viewport.classList.add('is-dragging');
        }
        function onMouseMove(e: MouseEvent) {
            if (!dragging) return;
            tx = dragOriginX + (e.clientX - dragStartX);
            ty = dragOriginY + (e.clientY - dragStartY);
            applyTransform();
        }
        function onMouseUp() {
            if (!dragging) return;
            dragging = false;
            viewport?.classList.remove('is-dragging');
        }

        // Initial + on Astro view-transition completion. Mermaid diagrams
        // render slightly after DOMContentLoaded — observe for late SVGs.
        function rerun() {
            attach();
            // The mermaid integration may render asynchronously; observe for
            // up to 5 seconds.
            let attempts = 0;
            const id = setInterval(() => {
                attach();
                if (++attempts > 20) clearInterval(id);
            }, 250);
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', rerun);
        } else {
            rerun();
        }
        // Astro view-transitions hook — re-attach on every navigation.
        document.addEventListener('astro:page-load', rerun);
    })();
</script>
