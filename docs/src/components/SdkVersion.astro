---
/**
 * SdkVersion — small badge above each SDK page header showing the
 * currently-shipping version, commit (when known), and a link to the
 * source repo.
 *
 * The TS entry is auto-refreshed by bin/update-sdk-versions.mjs before
 * each docs build. Go and PHP entries are hand-maintained in the JSON
 * (no tagged releases there yet) and render a "see GitHub" link rather
 * than a fake version number.
 *
 * Usage: <SdkVersion sdk="ts" />
 */
import sdkVersions from '../data/sdk-versions.json';

interface Props { sdk: 'ts' | 'go' | 'php' }
const { sdk } = Astro.props;
const info = sdkVersions[sdk];
const label = sdk === 'ts' ? '@rw3iss/tracker' : sdk === 'go' ? 'tracker-go' : 'rw3iss/tracker (PHP)';
---
<aside class="sdk-version">
  <span class="sdk-version__name">{label}</span>
  {info.version
    ? <span class="sdk-version__chip">v{info.version}</span>
    : <span class="sdk-version__chip sdk-version__chip--unreleased">unreleased</span>}
  {info.commit && <span class="sdk-version__commit">@ {info.commit}</span>}
  <span class="sdk-version__sep">·</span>
  <a href={info.repoUrl} target="_blank" rel="noopener">source</a>
  {info.registryUrl !== info.repoUrl && (
    <>
      <span class="sdk-version__sep">·</span>
      <a href={info.registryUrl} target="_blank" rel="noopener">{info.registry}</a>
    </>
  )}
</aside>

<style>
  .sdk-version {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    background: var(--sl-color-gray-7, var(--sl-color-bg));
    font-size: 0.875rem;
  }
  .sdk-version__name {
    font-family: var(--sl-font-mono);
    font-weight: 600;
  }
  .sdk-version__chip {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    font-family: var(--sl-font-mono);
    font-size: 0.8rem;
  }
  .sdk-version__chip--unreleased {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
  }
  .sdk-version__commit {
    font-family: var(--sl-font-mono);
    font-size: 0.8rem;
    color: var(--sl-color-text-accent, var(--sl-color-text));
  }
  .sdk-version__sep {
    color: var(--sl-color-gray-3);
  }
  .sdk-version a {
    color: var(--sl-color-text-accent, inherit);
  }
</style>
